# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/app"

# ── Auth / session ───────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="1d"

# ── Admin seed (prisma/seed.ts) ──────────────────────────────────────────────
ADMIN_EMAIL="admin@lebarregroup.com"
ADMIN_PASSWORD="change-me"

# ── Public site ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://lebarregroup.com"

# ── SMTP (Nodemailer) — optional; email queues to EmailOutbox when unset ──────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@lebarregroup.com"

# ── Cal.com embed ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CALCOM_LINK=""

# ── Cron / worker ────────────────────────────────────────────────────────────
CRON_SECRET="change-me"
