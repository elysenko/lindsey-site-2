// LeBarre Group — marketing site + lead funnel + admin CRM/CMS
// Prisma schema. Datasource: PostgreSQL.
// Auth model: admin_only — admin login only; User.role (ADMIN default, USER retained
// for future use) drives the AdminGuard. NestJS REST backend (no Pothos/tRPC).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  USER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

enum BriefStatus {
  PENDING
  COMPLETED
  SUPERSEDED
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

// ── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  insightsPosts InsightsPost[]
  leadNotes     LeadNote[]
  briefAudits   BrandBriefAudit[]
}

// ── Lead funnel ──────────────────────────────────────────────────────────────

model Lead {
  id                   String      @id @default(cuid())
  fullName             String
  organization         String?
  email                String
  phone                String?
  serviceInterest      String?
  challengeCategories  String[]    @default([])
  situationDescription String?     @db.Text
  briefToken           String      @unique
  briefStatus          BriefStatus @default(PENDING)
  leadStatus           LeadStatus  @default(NEW)
  ip                   String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  brief  BrandBrief?
  notes  LeadNote[]
  audits BrandBriefAudit[]

  @@index([leadStatus])
  @@index([briefStatus])
  @@index([createdAt])
}

model BrandBrief {
  id                String    @id @default(cuid())
  leadId            String    @unique
  mission           String?   @db.Text
  vision            String?   @db.Text
  differentiator    String?   @db.Text
  brandStory        String?   @db.Text
  audiences         String?   @db.Text
  brandVoice        String?   @db.Text
  successDefinition String?   @db.Text
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model BrandBriefAudit {
  id       String   @id @default(cuid())
  leadId   String
  field    String
  oldValue String?  @db.Text
  newValue String?  @db.Text
  adminId  String
  editedAt DateTime @default(now())

  lead  Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  admin User @relation(fields: [adminId], references: [id])

  @@index([leadId])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([leadId])
}

// ── Content ──────────────────────────────────────────────────────────────────

model TeamMember {
  id              String   @id @default(cuid())
  slug            String   @unique
  fullName        String
  title           String
  credentials     String?
  honorificPrefix String?
  bio             String   @db.Text
  expertise       String[] @default([])
  affiliations    String?  @db.Text
  headshotUrl     String?
  linkedinUrl     String?
  education       String?  @db.Text
  skills          String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InsightsPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  body        String     @db.Text
  authorId    String
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([status])
  @@index([publishedAt])
}

// ── Operational / infrastructure ─────────────────────────────────────────────

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  body      String      @db.Text
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([status])
}

model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  action    String
  createdAt DateTime @default(now())

  @@index([key, action, createdAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
